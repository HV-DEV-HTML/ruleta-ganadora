---
import chica_desktop from "@/assets/images/chica_desktop.webp";
---

<picture
  data-aos="zoom-in-up"
  class="w-full max-w-[296px] md:max-w-[320px] lg:max-w-[380px] xl:max-w-[480px] 2xl:max-w-[600px] h-auto block absolute -bottom-16 md:bottom-2 lg:bottom-1 xl:-bottom-73 2xl:-bottom-100 left-1/2 xl:left-14 2xl:-left-14 -translate-x-1/2 xl:translate-x-0 icon_girl"
>
  <source srcset={chica_desktop.src} media="(min-width: 1280px)" />
  <source srcset={chica_desktop.src} media="(min-width: 768px)" />
  <img
    class="w-full h-full object-cover relative left-0 xl:-left-3 2xl:left-35 imgMujer"
    src={chica_desktop.src}
    alt="Banner sorteo"
  />
</picture>
