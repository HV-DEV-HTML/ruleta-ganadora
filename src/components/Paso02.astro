      closeModal?.click();

      const c20peElement = document.querySelector(
        ".c20pe",
      ) as HTMLElement | null;
      if (!c20peElement) return;

      const yOffset = -80;
      const y =
        c20peElement.getBoundingClientRect().top + window.pageYOffset + yOffset;

      setTimeout(() => {
        window.scrollTo({
          top: y,
          behavior: "smooth",
        });
      }, 1000);

      setTimeout(() => {
        const actBtn = c20peElement.querySelector(
          ".actBtn",
        ) as HTMLElement | null;
        actBtn?.click();
      }, 600);
    });
  });
</script>
