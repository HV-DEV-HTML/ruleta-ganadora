  function elegirIndiceGanadorPorAngulo(
    anguloFinal: number,
    cantidadItems: number,
    gradosPorItem: number,
    offsetFlecha: number,
  ): number {
    // Normalizar el ángulo en el rango [0, 360)
    const anguloNormalizado = ((anguloFinal % 360) + 360) % 360;

    // Convertir al sistema usado para la ruleta:
    // en el cálculo original del ángulo objetivo se usaba:
    // anguloObjetivo = 360 - gradosPorItem * indice - gradosPorItem / 2 + offsetFlecha
    // Despejamos para obtener el índice aproximado a partir del ángulo observado.
    const anguloRelativo =
      (360 - (anguloNormalizado - offsetFlecha) + 360) % 360;

    let indice = Math.floor(anguloRelativo / gradosPorItem);

    if (indice < 0) indice = 0;
    if (indice >= cantidadItems) indice = cantidadItems - 1;

    return indice;
  }

