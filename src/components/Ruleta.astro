  const hasStockAvailable = (value) => {
    if (typeof value === "boolean") return value;
    if (typeof value === "number") return value > 0;
    if (typeof value === "string") {
      const normalized = value.trim().toLowerCase();
      return ["true", "1", "si", "sí", "yes"].includes(normalized);
    }
    return false;
  };

  async function girarRuleta() {
    const { user } = userStore.getState();
    const { fullClaro, product, detallePlay } = user;
    if (yaGiro) return;
    yaGiro = true;

    btnGirar.disabled = true;

    if (ruletaIntroTween) {
      ruletaIntroTween.kill();
      ruletaIntroTween = null;
    }
    gsap.killTweensOf(ruletaTable, "rotation");
    const isUserFijaFullClaro100Mbps =
      fullClaro === false && product === "Fija" && detallePlay === "1000";
    const categoryIdExclude = isUserFijaFullClaro100Mbps ? 10 : null; //No debe caer en bonos

    try {
      const latestProductsResponse = await getListProducts(
        user.provinceId,
        user.serviceId,
      );
      const latestProducts = latestProductsResponse?.data || [];
      const latestStockByPrizeType = new Map(
        latestProducts.map((product) => [
          Number(product.prizeTypeId),
          hasStockAvailable(product.hasStock),
        ]),
      );
      const combosProduct = latestProducts.find(
        (product) => product.prizeTypeName === "Combos",
      );
      const comboSubtypeStock = new Map(
        (combosProduct?.subtypes || []).map((subtype) => [
          Number(subtype.id),
          hasStockAvailable(subtype.hasStock),
        ]),
      );

      items.forEach((item) => {
        const categoryId = Number(item.getAttribute("data-category_id"));
        if (!Number.isFinite(categoryId)) {
          item.setAttribute("data-stock", "0");
          return;
        }
        const hasStock = latestStockByPrizeType.has(categoryId)
          ? latestStockByPrizeType.get(categoryId)
          : comboSubtypeStock.get(categoryId);
        if (hasStock === undefined) {
          item.setAttribute("data-stock", "0");
          return;
        }
        item.setAttribute("data-stock", hasStock ? "1" : "0");
      });
    } catch (error) {
      console.error("Error al revalidar stock antes del giro:", error);
      showCustomModal({
        title: "No se pudo validar stock",
        html: `<p>Inténtalo nuevamente en unos segundos.</p>`,
        iconSrc: icon_no_cumple.src,
        confirmButtonText: "Entendido",
        showCloseButton: false,
      });
      yaGiro = false;
      btnGirar.disabled = false;
      return;
    }

    // Filtrar solo los ítems con stock > 0
    const itemsDisponibles: { index: number; element: Element }[] = [];
    items.forEach((item, index) => {
      const stockAttr = item.getAttribute("data-stock");
      const stock = stockAttr ? Number(stockAttr) : 0;
      const categoryId = Number(item.getAttribute("data-category_id"));
      // Regla especial: si el usuario es Fija Full Claro 100Mbps,
      // se excluye una categoría específica para que no sea elegible al giro.
      // categoryIdExclude será null si la regla no aplica.
      const isExcludedCategory =
        Number.isFinite(categoryId) && categoryIdExclude === categoryId;
      if (stock > 0 && !isExcludedCategory) {
        itemsDisponibles.push({ index, element: item });
      }
    });
    // Si no hay ítems disponibles, cancelamos el giro y reactivamos el botón
    if (itemsDisponibles.length === 0) {
      console.warn(
        "No hay ítems disponibles con stock > 0 para girar la ruleta.",
      );
      showCustomModal({
        title: "Lo sentimos, no puedes participar en estos momentos 👇",
        html: `<p>No hay premios disponibles para girar la ruleta.</p>`,
        iconSrc: icon_no_cumple.src,
        confirmButtonText: "Volver al inicio",
        showCloseButton: false,
        onConfirm: () => {
          resetRuleta();
        },
      });
      yaGiro = false;
      btnGirar.disabled = true;
      return;
    }

    // Usamos la circunferencia completa para que cada premio ocupe el mismo ángulo
    const gradosPorItem = 360 / items.length;
    const vueltasExtras = 360 * 10;
    const offsetFlecha = 20;

    // Elegimos aleatoriamente uno de los items disponibles (con stock > 0)
    const indiceArray = Math.floor(Math.random() * itemsDisponibles.length);
    const indiceGanador = itemsDisponibles[indiceArray].index;

    // Calculamos el ángulo objetivo para que la flecha quede cerca del centro del premio ganador
    const anguloObjetivo =
      360 - gradosPorItem * indiceGanador - gradosPorItem / 2 + offsetFlecha;
    const anguloFinal = gradosActuales + vueltasExtras + anguloObjetivo;

    gsap.to(ruletaTable, {
      rotation: anguloFinal,
      duration: 10,
      ease: "power3.out",
      onComplete: async () => {
        const itemGanador = items[indiceGanador];
        const category_id = itemGanador.getAttribute("data-category_id");
        const category_name = itemGanador.getAttribute("data-nombre");
        //console.log(`Categoría Ganador: ${category_name}, con ID ${category_id}`);
        if (!category_id || Number.isNaN(Number(category_id))) {
          showCustomModal({
            title: "No se pudo registrar el giro",
            html: `<p>No se encontró una categoría válida para este premio.</p>`,
            iconSrc: icon_no_cumple.src,
            confirmButtonText: "Volver al inicio",
            showCloseButton: false,
            onConfirm: () => {
              resetRuleta();
            },
          });
          return;
        }
        // Después del giro mostrar modal
        btnGirar.disabled = false;
        try {
          //console.log("Giro completado");
          const spinSaveResultResponse = await spinSaveResult(
            user.serviceId,
            Number(category_id),
          );
          //console.log({ spinSaveResultResponse });
          if (spinSaveResultResponse?.result === "WIN") {
            showModalWin(spinSaveResultResponse, user);
          } else if (spinSaveResultResponse?.result === "NO_STOCK") {
            showCustomModal({
              title: "Lo sentimos, no hay stock disponible",
              html: `<p>${spinSaveResultResponse?.message || "No hay premios disponibles para esta categoría en este momento."}</p>`,
              iconSrc: icon_no_cumple.src,
              confirmButtonText: "Volver al inicio",
              showCloseButton: false,
              onConfirm: () => {
                resetRuleta();
              },
            });
          } else {
            showCustomModal({
              title: "Resultado de tu jugada",
              html: `<p>${spinSaveResultResponse?.message || "No fue posible registrar el resultado del giro."}</p>`,
              iconSrc: icon_no_cumple.src,
              confirmButtonText: "Volver al inicio",
              showCloseButton: false,
              onConfirm: () => {
                resetRuleta();
              },
            });
          }
        } catch (error) {
          console.error("Error en spinSaveResult:", error);
          const resultCode = String(error?.result || "").toUpperCase();
          const errorMessage =
            error?.apiMessage || error?.message || "Error al procesar el giro.";

          if (
            resultCode === "NO_STOCK" ||
            String(errorMessage).toLowerCase().includes("stock")
          ) {
            showCustomModal({
              title: "Lo sentimos, no hay stock disponible",
              html: `<p>No hay premios disponibles para esta categoría en este momento.</p>`,
              iconSrc: icon_no_cumple.src,
              confirmButtonText: "Volver al inicio",
              showCloseButton: false,
              onConfirm: () => {
                resetRuleta();
              },
            });
          } else {
            showCustomModal({
              title: "Ocurrió un problema al registrar tu jugada",
              html: `<p>Por favor, intenta nuevamente.</p>`,
              iconSrc: icon_no_cumple.src,
              confirmButtonText: "Entendido",
              showCloseButton: false,
            });
          }
        } finally {
          togglePreloadAnimation(false);
        }
      },
    });

    gradosActuales = anguloFinal;
  }

